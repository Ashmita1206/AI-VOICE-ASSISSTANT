# ==============================================================
# AI Voice Assistant — Environment Configuration
# ==============================================================

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Flask Server Port (default: 5000)
FLASK_PORT=5000

# Remote LLM Planner endpoint (ngrok URL or localhost)
COLAB_API_URL=https://evaluator-agreeing-plenty.ngrok-free.dev/plan
COLAB_TIMEOUT=120

# Faster-Whisper Model Settings (used when STT_USE_REMOTE=false)
STT_MODEL_ID=deepdml/faster-whisper-large-v3-turbo-ct2
STT_BEAM_SIZE=5
STT_VAD_FILTER=True

# ---------------------------------------------------------------
# Remote STT (Colab GPU) — optional
# ---------------------------------------------------------------
# Set STT_USE_REMOTE=true to offload transcription to the Colab
# GPU server (see colab_stt_server.ipynb).
#
# Steps:
#   1. Open colab_stt_server.ipynb in Google Colab
#   2. Set Runtime -> GPU (T4 or better)
#   3. Run the notebook and copy the ngrok URL it prints
#   4. Paste the URL below and set STT_USE_REMOTE=true
# ---------------------------------------------------------------
STT_USE_REMOTE=false
STT_API_URL=https://REPLACE_WITH_YOUR_NGROK_URL.ngrok-free.app/transcribe
STT_API_TIMEOUT=60

# Voice Activity Detection (VAD) Silence Parameters
SILENCE_THRESHOLD=0.01
SILENCE_DURATION=2.0
